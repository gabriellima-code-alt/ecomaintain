# ============================================
# VARIÁVEIS DE AMBIENTE - EcoMaintain
# ============================================
# Copie este arquivo para .env.local para desenvolvimento local
# Na Vercel, configure estas variáveis no painel de Settings > Environment Variables

# String de conexão com o banco de dados Neon (PostgreSQL)
# Obtenha no painel do Neon: https://console.neon.tech
# Formato: postgresql://usuario:senha@host/banco?sslmode=require
DATABASE_URL=postgresql://usuario:senha@ep-xxxxx.us-east-2.aws.neon.tech/ecomaintain?sslmode=require
